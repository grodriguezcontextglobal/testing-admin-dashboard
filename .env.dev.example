# ── Devitrak Client — Variables de entorno de desarrollo ──────────────────────
#
# Copia este archivo a .env.dev y completa los valores de desarrollo.
# NUNCA uses credenciales de producción aquí.
# Este archivo (.env.dev.example) SÍ se commitea. El archivo .env.dev NO.
#
# Instrucciones:
#   cp .env.dev.example .env.dev
#   # Edita .env.dev con los valores del entorno de desarrollo

# ── APIs del backend ───────────────────────────────────────────────────────────
VITE_APP_DEVITRACK_API=
VITE_APP_DEVITRACK_API_BACKUP=
VITE_APP_DEVITRAK_CONSUMER_API=
VITE_APP_AWS_API=

# ── Autenticación / Seguridad ──────────────────────────────────────────────────
VITE_APP_AWS_HEADER_AUTH=

# ── Stripe (usar clave de TEST para desarrollo) ────────────────────────────────
# La clave pública de test empieza con pk_test_
VITE_APP_PUBLIC_STRIPE_KEY=pk_test_

# ── Cloudflare Turnstile reCAPTCHA ────────────────────────────────────────────
VITE_APP_RECAPTCHA_SITEKEY=

# ── Twilio (SMS) ──────────────────────────────────────────────────────────────
VITE_APP_TWILIO_SID=
VITE_APP_TWILIO_TOKEN=

# ── Cifrado local ─────────────────────────────────────────────────────────────
VITE_APP_ENCRYPTION_ALGORITHM=aes-256-cbc
VITE_APP_SECRET_KEY=

# ── Puertos (no modificar salvo conflicto local) ──────────────────────────────
VITE_APP_PORT=5522
VITE_APP_SSR_PORT=5523

# ── Feature flags ──────────────────────────────────────────────────────────────
# Scoped roles (location/category), Phase A groundwork — default OFF. Backend
# rejects the new role_types today; do not enable outside local testing.
VITE_APP_FEATURE_SCOPED_ROLES=false
